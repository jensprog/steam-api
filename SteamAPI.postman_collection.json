				{
					"name": "Login - Valid Credentials",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200 for successful login\", function() {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Content-Type is application/json\", function() {",
									"    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
									"});",
									"",
									"pm.test(\"Response contains JWT token\", function() {",
									"    const responseJson = pm.response.json();",
									"    pm.expect(responseJson).to.have.property('access_token');",
									"    pm.expect(responseJson).to.have.property('token_type');",
									"    pm.expect(responseJson.access_token.length).to.be.greaterThan(0);",
									"});",
									"",
									"pm.test(\"Save JWT token for other tests\", function() {",
									"    const responseJson = pm.response.json();",
									"    pm.environment.set(\"jwt_token\", responseJson.access_token);",
									"});"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"pm.environment.set(\"login_username\",",
									"pm.environment.get(\"register_username\"));"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
